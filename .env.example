# QuizGPT Environment Configuration Template

# Copy this file to .env and fill in your values
# DO NOT commit .env to version control (it's in .gitignore)

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Specify which model to use (defaults to gpt-4o-mini)
# Options: gpt-4, gpt-4o-mini, gpt-4-turbo, etc.
# OPENAI_MODEL=gpt-4o-mini

# Optional: Override API base URL (for custom deployments)
# OPENAI_API_BASE=https://api.openai.com/v1

# Logging Configuration (optional)
# LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# Feature Flags (optional)
# ENABLE_DEDUPLICATION=true
# ENABLE_DIMENSION_EXTRACTION=true

# Performance Tuning (optional)
# MAX_WORKERS=4  # Number of threads for concurrent requests
# MAX_QUESTIONS_PER_REQUEST=10  # Should stay at 10 for LLM limits
# OVER_GENERATION_FACTOR=1.2  # Generate 20% extra to account for duplicates

# FAISS Configuration (optional)
# SIMILARITY_THRESHOLD=0.90  # 0-1, higher = stricter deduplication
# EMBED_MODEL=text-embedding-3-small  # Embedding model for deduplication
